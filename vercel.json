{
  "rewrites": [
    { "source": "/", "destination": "/index.dc.html" },
    { "source": "/about", "destination": "/about.dc.html" },
    { "source": "/blog", "destination": "/blog.dc.html" },
    { "source": "/contact", "destination": "/contact.dc.html" },
    { "source": "/services", "destination": "/services.dc.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
